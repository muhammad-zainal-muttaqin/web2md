{
  "manifest_version": 3,
  "name": "web2md",
  "version": "1.1.0",
  "description": "Convert any web page to clean Markdown. Read the current tab or paste HTML.",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "web2md"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
